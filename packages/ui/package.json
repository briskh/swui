{
  "name": "@swui/ui",
  "version": "1.0.0",
  "description": "swui React UI primitives with global theme provider",
  "type": "module",
  "sideEffects": false,
  "files": [
    "AGENTS.md",
    "README.md",
    "docs",
    "llms.txt",
    "src"
  ],
  "exports": {
    ".": "./src/index.ts",
    "./utils": "./src/lib/utils.ts",
    "./date": "./src/lib/date.ts",
    "./theme": "./src/theme.tsx",
    "./package.json": "./package.json",
    "./*": "./src/components/*.tsx",
    "./AGENTS.md": "./AGENTS.md",
    "./llms.txt": "./llms.txt",
    "./docs/*": "./docs/*"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.0.0",
    "@hookform/resolvers": "^5.0.0",
    "zod": "^4.0.0",
    "lucide-react": ">=0.400.0",
    "clsx": "^2.0.0",
    "tailwind-merge": "^3.0.0",
    "class-variance-authority": "^0.7.0",
    "cmdk": "^1.0.0",
    "date-fns": "^4.0.0",
    "react-day-picker": "^9.0.0 || ^10.0.0",
    "sonner": "^2.0.0",
    "recharts": "^3.0.0",
    "@tanstack/react-table": "^8.0.0",
    "@radix-ui/react-accordion": "*",
    "@radix-ui/react-alert-dialog": "*",
    "@radix-ui/react-avatar": "*",
    "@radix-ui/react-checkbox": "*",
    "@radix-ui/react-collapsible": "*",
    "@radix-ui/react-context-menu": "*",
    "@radix-ui/react-dialog": "*",
    "@radix-ui/react-dropdown-menu": "*",
    "@radix-ui/react-hover-card": "*",
    "@radix-ui/react-label": "*",
    "@radix-ui/react-popover": "*",
    "@radix-ui/react-progress": "*",
    "@radix-ui/react-radio-group": "*",
    "@radix-ui/react-scroll-area": "*",
    "@radix-ui/react-select": "*",
    "@radix-ui/react-separator": "*",
    "@radix-ui/react-slider": "*",
    "@radix-ui/react-slot": "*",
    "@radix-ui/react-switch": "*",
    "@radix-ui/react-tabs": "*",
    "@radix-ui/react-toggle": "*",
    "@radix-ui/react-toggle-group": "*",
    "@radix-ui/react-tooltip": "*"
  },
  "publishConfig": {
    "access": "restricted",
    "registry": "https://npm.inet.swqt.net/"
  },
  "scripts": {
    "pack": "bun pm pack",
    "publish:dry": "npm publish --dry-run --registry \"${SWUI_NPM_REGISTRY:-https://npm.inet.swqt.net/}\""
  },
  "devDependencies": {
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "typescript": "^5.9.3"
  }
}
