{
  "name": "@swqt/ui-tokens",
  "version": "1.1.0",
  "description": "swui design tokens (CSS variables + Tailwind v4 theme bridges)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/briskh/swui.git",
    "directory": "packages/ui-tokens"
  },
  "type": "module",
  "files": [
    "AGENTS.md",
    "README.md",
    "docs",
    "llms.txt",
    "src"
  ],
  "exports": {
    ".": "./src/tokens.css",
    "./tokens.css": "./src/tokens.css",
    "./package.json": "./package.json",
    "./AGENTS.md": "./AGENTS.md",
    "./llms.txt": "./llms.txt",
    "./docs/*": "./docs/*"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "pack": "bun pm pack",
    "publish:dry": "npm publish --dry-run --registry \"${SWUI_NPM_REGISTRY:-https://registry.npmjs.org/}\""
  }
}
