{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "isolatedModules": true,
    "paths": {
      "@swqt/ui": [
        "../../packages/ui/src/index.ts"
      ],
      "@swqt/ui/*": [
        "../../packages/ui/src/components/*"
      ],
      "@swqt/ui/utils": [
        "../../packages/ui/src/lib/utils.ts"
      ],
      "@swqt/ui/theme": [
        "../../packages/ui/src/theme.tsx"
      ]
    }
  },
  "include": [
    "src",
    "vite.config.ts"
  ]
}
