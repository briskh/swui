{
  "version": 1,
  "hooks": {
    "beforeMCPExecution": [
      {
        "command": "sw hook beforeMCPExecution"
      }
    ],
    "afterMCPExecution": [
      {
        "command": "sw hook afterMCPExecution"
      }
    ],
    "beforeReadFile": [
      {
        "command": "sw hook beforeReadFile"
      }
    ],
    "postToolUse": [
      {
        "command": "sw hook postToolUse",
        "matcher": "Read"
      }
    ],
    "sessionStart": [
      {
        "command": "sw hook sessionStart"
      }
    ],
    "beforeShellExecution": [
      {
        "command": "sw hook beforeShellExecution"
      }
    ],
    "beforeSubmitPrompt": [
      {
        "command": "sw hook beforeSubmitPrompt"
      }
    ]
  }
}
